{
  "name": "portx",
  "version": "0.1.0",
  "description": "A tiny macOS-first CLI to list, inspect, stop, and restart local port processes.",
  "type": "module",
  "bin": {
    "portx": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "cli",
    "ports",
    "lsof",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "ink": "^5.1.0",
    "lowdb": "^7.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
